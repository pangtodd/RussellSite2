---
title: Mark Russell bibliography
image: https://stirring-beignet-ce08d6.netlify.app/images/flickCroppy.webp
description: complete bibliography of Mark Russell's published works.
layout: base.njk
--- 

<div class="hero">
  <picture>
    <source 
      media="(min-width: 768px)" 
      srcset="https://res.cloudinary.com/dfbfqlfkc/image/upload/c_fill,g_auto,w_1400,h_400,q_auto,f_auto/v1778988974/disappointed-cropped_qgt48g"
      width="1400"
      height="400"
    >
    
    <img 
      src="https://res.cloudinary.com/dfbfqlfkc/image/upload/c_fill,g_auto,w_450,h_190,q_auto,f_auto/v1778988974/disappointed-cropped_qgt48g" 
      class="d-block w-100 booksHero" 
      alt="Hero Image"
      width="450"
      height="190"
      loading="eager"
      fetchpriority="high"
    >
  </picture>
</div>
<div class="container mt-3">

<section id="books">
  <div class="container mt-3">
    <h1 class="text-center">Books</h1>
    <h2 class="text-center">Comic books. And book books.</h2>
    <!-- Visible cards section -->
    {% set books = collections.books %}
    {% if books.length > 0 %}
      {% for book in books %}
        {% if loop.index0 % 4 ==0 %}
          <div class="row">
        {% endif %}
      <div class="col-lg-3 mt-3">
        <div class="card">
          <div class="image">
            {% if "https://res.cloudinary.com" in book.data.image %}
            <img 
              src="{{ book.data.image | replace('/upload/', '/upload/q_auto:eco,f_auto,w_300/') }}"
              srcset="
                {{ book.data.image | replace('/upload/', '/upload/q_auto:eco,f_auto,w_300/') }} 300w,
                {{ book.data.image | replace('/upload/', '/upload/q_auto:eco,f_auto,w_450/') }} 450w,
                {{ book.data.image | replace('/upload/', '/upload/q_auto:eco,f_auto,w_600/') }} 600w
              "
              sizes="(max-width: 450px) 100vw, (max-width: 767px) 50vw, 300px"
              class="card-img-top" 
              alt="cover of {{ book.data.title }}"
              {%if loop.index == 1%} 
              loading="eager"
              fetchpriority="high"
              {% elif loop.index> 8 %}
              loading="lazy"
              {% endif %}
            >
          {% else %}
            <!-- OLD LOCAL CODE (Fallback for assets still on your hard drive) -->
            <img
              class="card-img-top"
              src="{{ book.data.image }}"
              alt="cover of {{ book.data.title }}"
            >
          {% endif %}
          </div>
          <div class="details">
            <div class="center">
              <h3>{{ book.data.title }}</h3>
              <p>
                {{ book.content | safe }}
                {%if book.data.quote%}
                  <br />-{{book.data.quote}} 
                {% endif %}
                <br />Art by {{book.data.artist}}
              </p>
              <a
                href="{{book.data.link}}"
                class="btn btn-success"
                >buy now</a
              >
            </div>
          </div>
        </div>
      </div>
      {% if loop.index % 4 == 0 or loop.last%}
        </div>
      {% endif %}
    {% endfor %}
    {% endif %}
</section>